// Test file for activeDefinition grammar
// Exercises all compiler-verified forms of "active" blocks

class ActiveTests {

  // Form B: no name, no lang tag
  active { doWork(); }

  // Form B: thread name, no lang tag
  active Worker { doWork(); }

  // Form B: lang tag inside more_code (no thread name)
  active Java { System.out.println("java work"); }

  // Form A: prefix lang tag + thread name
  active Cpp Worker { printf("cpp work"); }

  // Form A: prefix lang tag (Java) + thread name
  active Java Worker { System.out.println("java worker"); }

  // Form B: thread name, lang inside more_code
  active Worker Java { System.out.println("worker java"); }

  // Form B: thread name, multiple lang-tagged blocks
  active Worker Java { System.out.println("java"); } Cpp { printf("cpp"); }

  // Form B: multiple lang-tagged blocks, no thread name
  active Java { System.out.println("java"); } Cpp { printf("cpp"); }

  // Form A: comma-separated prefix langs + name
  // NOTE: spec-valid but crashes current compiler with E9100 (NullPointerException)
  // active Java, Cpp Worker { doWork(); }

}
