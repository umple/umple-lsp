// T2 defined BEFORE T1 to test trait-scoped event extraction
// (must not leak z9 into T1's completion)
trait T2 {
  sm {
    wrong { z9 -> wrong; }
  }
}

trait T1 {
  sm {
    s1 {
      e1 -> s2;
      e2(Integer x) -> s2;
      inner1 {}
      inner2 {}
    }
    s2 {
      e3 -> s1;
    }
    s3 {}
  }
  sm2 {
    x1 {}
    x2 {}
  }
}
