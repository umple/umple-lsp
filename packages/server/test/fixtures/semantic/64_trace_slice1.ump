// Trace Slice 1: tracer directives + comma-separated entities

// Bare tracer directives
tracer Console;
tracer log4j;
tracer File;
tracer String;

// Tracer with logConfig options
tracer log4j Level = 2;
tracer log4j root = all;
tracer log4j debug = console fatal = file;
tracer log4j debug,error = console,file;
tracer log4j root=all debug=console monitorInterval=30;
tracer String maxRecords = 100;

// Tracer with message header
tracer console on : Time,Object;

// Tracer with trailing argument
tracer log4j noConfig;
tracer File "mylog.txt";

// Full combo
tracer log4j root = all debug = console on : Time,Object noConfig;

class A {
  /*@attr_name*/name;
  Integer /*@attr_age*/age;
  Boolean enabled;

  // Comma-separated trace entities — later items must have semantics
  trace name, /*@trace_age_ref*/age;
  trace name(), age();
  trace name, age, enabled;

  // Comma-separated with postfix
  trace name, age where [age > 5];
  trace name, enabled record age;

  // Existing single-entity forms (regression)
  trace name;
  trace name();
  trace age where [age > 5];
  trace name until [age > 10];
}
