class Component1 {
  public in Integer /*@port_in1*/pIn1;
  public out Integer /*@port_out1*/pOut1;
  /*@port_in1_ref*/pIn1 -> /*@port_out1_ref*/pOut1;

  [pIn1]
  active /*@active_increment*/increment {
    pOut1(pIn1 + 1);
  }

  [pOut1]
  active logOutPort1 {
    cout << pOut1;
  }
}

class Component2 {
  public in Integer /*@port_in2*/pIn2;
  public out Integer /*@port_out2*/pOut2;
  /*@port_in2_ref*/pIn2 -> /*@port_out2_ref*/pOut2;

  [pIn2, pIn2 < 10]
  active stop {
    pOut2(pIn2 + 1);
  }
}

class Composite {
  Component1 /*@component_cmp1*/cmp1;
  Component2 /*@component_cmp2*/cmp2;
  /*@cmp1_ref*/cmp1./*@cmp1_pout1_ref*/pOut1 -> /*@cmp2_ref*/cmp2./*@cmp2_pin2_ref*/pIn2;
  /*@cmp2_ref_2*/cmp2./*@cmp2_pout2_ref*/pOut2 -> /*@cmp1_ref_2*/cmp1./*@cmp1_pin1_ref*/pIn1;
}

class Sensor {
  public out int /*@port_speed*/speed;
  this./*@sensor_data_ref*/data -> client./*@client_sensor_data_ref*/sensorData { return new SensorData(); }

  [sensorData]
  void active /*@active_init*/init() {
    doInit();
  }

  [clientData, period(1), sensorData != null]
  void active computeData {
    compute();
  }
}
