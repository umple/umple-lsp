trait T1 {
  sm1 { s1 { e1 -> s2; } s2 {} }
}

class A {
  isA T1<-sm1>;
}

class B {
  isA T1<+sm1.s1>;
}

class C {
  isA T1<-sm1.s2>;
}

class D {
  status { on {} off {} }
  isA T1<sm1 as status.on>;
}

class E {
  isA T1<sm1.e1(Integer) as event1>;
}

class F {
  isA T1<sm1.s1() as end>;
}

class G {
  isA T1<+sm1.s1.e1(Integer)>;
}
