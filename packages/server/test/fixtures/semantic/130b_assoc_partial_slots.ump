// Phase 042 — partial association slot probes. Fixture intentionally has
// ERROR nodes where the parser's mid-way through an association. Declaration
// types live in 130_assoc_partial_completion.ump (imported via use below).

use "130_assoc_partial_completion.ump";

class ClassBodyAfterArrow {
  1 -> /*@class_body_after_arrow*/
}

class ClassBodyAfterRightMult {
  1 -> * /*@class_body_after_right_mult*/
}

class ClassBodyAfterRangeMult {
  0..1 -> 1..* /*@class_body_after_range_mult*/
}

class ClassBodyDashVariant {
  1 -- * /*@class_body_dash_variant*/
}

// state body with `e -> |` must remain a transition_target, not association.
class NegState {
  status {
    S1 {
      e -> /*@state_body_arrow*/
    }
    S2 {}
  }
}

// Top-level `association { ... }` block — mixed partial associations cascade
// into one sprawling ERROR, which is the shape codex's bug repro hit.
// All three cursors must still route correctly.
association {
  1 Other -> /*@assoc_block_after_arrow*/
  1 Other -> * /*@assoc_block_after_right_mult*/
  0..1 Other -> 1..* /*@assoc_block_after_range_mult*/
}

// Topic 043 — typed-prefix on the right_type identifier. Cursor sits INSIDE
// the partial identifier the user is still typing. Must offer class /
// interface / trait symbols only — no class-body keyword junk.
class ClassBodyTypedPrefix {
  1 -> * O/*@class_body_typed_prefix*/
}

association {
  1 Other -> * O/*@assoc_block_typed_prefix*/
}

association {
  1 O/*@assoc_block_left_type_typed*/
}

// Topic 044 — arrow slot. Class-body inline associations offer arrows after
// the left multiplicity. Standalone association blocks offer a left type
// first, then arrows after that type.
class ClassBodyArrowSlot {
  1 /*@class_body_arrow_blank*/
}

class ClassBodyArrowPartial {
  1 -/*@class_body_arrow_dash*/
}

class ClassBodyArrowAggregation {
  1 <@/*@class_body_arrow_aggregation*/
}

association {
  1 /*@assoc_block_left_type_blank*/
}

association {
  1 Other /*@assoc_block_arrow_blank*/
}

association {
  1 Other -/*@assoc_block_arrow_dash*/
}

association {
  1 -> /*@assoc_block_missing_left_type*/
}

// Standalone cascade — second member after a completed member. These pin that
// segment detection does not inherit the prior member's arrow or right type.
association {
  1 Other -> * Thing;
  1 /*@assoc_block_cascade_left_type*/
}

association {
  1 Other -> * Thing;
  1 Other /*@assoc_block_cascade_arrow_slot*/
}

association {
  1 Other -> * Thing;
  1 Other -> /*@assoc_block_cascade_mult_slot*/
}

// Cascade — second association's left mult after a complete first one.
class CascadeArrow {
  1 -> * Other;
  1 /*@cascade_arrow_slot*/
}
