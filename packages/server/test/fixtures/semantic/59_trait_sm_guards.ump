// Phase 3: trait SM guard operations + goto-def semantics
// All forms below are compiler-verified valid syntax

trait T1 {
  /*@sm_decl*/sm {
    /*@s1_decl*/s1 {
      /*@e4_decl*/e4 [cond] -> s2;
      /*@e5_decl*/e5 -> s2;
    }
    /*@s2_decl*/s2 {
      [cond] -> s1;
      e6 -> s1;
      // Same name, different params for signature disambiguation
      /*@e4_int_decl*/e4(Integer x) -> s1;
      // Same exact signature, multiple transitions (different guards)
      /*@e4_dup1*/e4 [!cond] -> s3;
      /*@e4_dup2*/e4 -> s1;
    }
    /*@s3_decl*/s3 {
      -> s1;
      e7 -> s1;
    }
  }
}

// Phase 3 form 1: event removal with guard
class A {
  Boolean cond;
  isA T1<-/*@op_sm1*/sm./*@op_s1*/s1./*@op_e4*/e4()[cond]>;
}

// Phase 3 form 2: guarded auto-transition removal
class B {
  Boolean cond;
  isA T1<-/*@op_sm2*/sm./*@op_s2*/s2.[cond]>;
}

// Phase 3 form 3: empty guard removal
class C {
  isA T1<-/*@op_sm3*/sm./*@op_s3*/s3.[]>;
}

// Phase 3 with + prefix
class D {
  Boolean cond;
  isA T1<+/*@op_sm4*/sm./*@op_s1b*/s1.e4()[cond]>;
}

// Phase 1 regression
class P1 {
  isA T1<-/*@op_sm_p1*/sm>;
}

// Phase 2 regression: sm.e4() as newEvent
class P2 {
  isA T1</*@op_sm_p2*/sm./*@op_e4_p2*/e4() as /*@op_newevt*/newEvent>;
}

// Param disambiguation: e4(Integer) → different from e4()
class P3 {
  isA T1<-sm.s2./*@op_e4_int*/e4(Integer)>;
}

// Multi-result: e4() in s2 has two transitions (different guards)
class P4 {
  isA T1<-sm.s2./*@op_e4_multi*/e4()>;
}
