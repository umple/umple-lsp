namespace example;

tracer log4j;

class TraceVariants {
  Integer /*@def_id*/id;
  Integer /*@def_contact*/contact;
  String /*@def_name*/name;

  /*@def_status*/status {
    Open { /*@event_flip_open*/flip -> Closed; }
    /*@def_closed*/Closed { /*@event_flip_closed*/flip -> Open; }
  }

  trace *attributes;
  trace onlyGet /*@onlyget_id_ref*/id, /*@onlyget_name_ref*/name;
  trace /*@trace_sm_ref*/status./*@trace_closed_ref*/Closed;
  trace /*@trace_name_ref*/name record /*@record_id_ref*/id,/*@record_contact_ref*/contact;
  trace name record only /*@record_only_id_ref*/id;
  trace name logLevel debug,fatal;
  trace transition /*@transition_event_ref*/flip record /*@transition_record_contact_ref*/contact;

  tracecase /*@tc1_def*/tc1 {
    trace name;
  }
  deactivate /*@deact_tc1_ref*/tc1 onThisObject for 1s;
}
