class OtherClass {
  sm { WrongState {} }
}

class A {
  /*@tpc_name*/name;
  Integer age;
  void /*@tpc_open*/open() {}
  sm {
    Open {}
    Closed {}
  }

  // Later prefixed state entity completion
  trace entry,exit Open, /*@tpc_comp_entry_later*/ ;

  // Later prefixed attribute entity completion
  trace set,get name, /*@tpc_comp_set_later*/ ;

  // Later onlyGet attribute entity completion
  trace onlyGet name, /*@tpc_comp_onlyget_later*/ ;

  // Blank later slot under exit with call-form sibling → union
  trace exit open(), /*@tpc_comp_exit_blank_later*/ ;

  // Concrete call-form: marker inside existing trace_entity_call
  trace exit /*@tpc_comp_exit_call_concrete*/open(), Open;

  // Mixed form: bare entity in a list with call-form sibling
  trace exit /*@tpc_comp_exit_bare_mixed*/Open, open();

  // add/remove suppressed
  trace add /*@tpc_comp_add*/ ;

  // transition events are not indexed as normal symbols
  trace transition /*@tpc_comp_transition*/ ;
}
