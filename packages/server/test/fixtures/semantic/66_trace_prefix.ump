class B {}

class A {
  /*@pref_attr_name*/name;
  Integer /*@pref_attr_age*/age;
  void /*@pref_method_open*/open() {}
  /*@pref_sm*/sm {
    /*@pref_state_open*/Open {
      close -> Closed;
    }
    Closed {}
  }
  0..1 -- * B /*@pref_assoc_manager*/manager;

  // entry bare → state
  trace entry /*@trace_entry_state*/Open;

  // exit call → method
  trace exit /*@trace_exit_method*/open();

  // set → attribute
  trace set /*@trace_set_attr*/name;

  // add → association
  trace add /*@trace_add_assoc*/manager;

  // no prefix → attribute/method
  trace /*@trace_noprefix*/name;

  // multi-prefix + multi-entity
  trace set,get name, /*@trace_multi_age*/age;
}
