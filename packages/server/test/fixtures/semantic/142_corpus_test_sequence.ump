generate Test;

class Person {
  testSequence ts {
    /*@seq_check_name*/checkName -> /*@seq_check_status*/checkStatus;
  }

  test /*@test_check_name*/checkName {
    for (Job job : jobs) {
      assertTrue(job.getName() != "Coach");
    }
  }

  before test setUp {
    // initialize environment
  }

  after test teardown {
    // delete files
  }

  JUnit concrete test /*@test_check_status*/checkStatus {
    before assertFalse(d1.firstName() == "Orlean");
    after assertFalse(p1.getId() == "something");
  }
}

class Student {
  isA Person;

  override test /*@student_test_check_name*/checkName {
    assertTrue(id == 2);
  }
}
