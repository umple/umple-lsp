// Phase C1+C2 — implementsReq legal across every context enumerated in
// compiler issue #2098. Markers pin goto-def, find-refs, and completion
// assertions in semantic.test.ts.

req /*@def_r1*/R1 text { Top-level contexts }
req /*@def_r2*/R2 text { Inside association block }
req /*@def_r3*/R3 text { Inside state machine }
req /*@def_r4*/R4 text { Inside state }
req /*@def_r5*/R5 text { Inside top-level statemachine }

// Top-level: implementsReq before trait / interface / enum / top-level
// association / top-level statemachine / another req / a class (existing).
implementsReq /*@use_r1_trait*/R1;
trait T { name; }

implementsReq /*@use_r1_iface*/R1;
interface IX { void doSomething(); }

implementsReq /*@use_r1_enum*/R1;
enum Color { RED, GREEN, BLUE }

class Student {}
class Course {}
implementsReq /*@use_r1_assoc*/R1;
association { * Student -- * Course; }

implementsReq /*@use_r1_sm*/R1;
statemachine TopSM {
  implementsReq /*@use_r5_sm*/R5;
  On { -> Off; }
  Off {}
}

implementsReq /*@use_r1_req*/R1;
req Detailed text { The system shall do X when Y }

// Inside association block: implementsReq attaches to the next association_member.
class Dept {}
association {
  implementsReq /*@use_r2_assocblk*/R2;
  * Student -- * Course;
  * Course -- 1 Dept;
}

// Inside class-local state machine body: implementsReq at SM root and inside a state.
class X {
  status {
    implementsReq /*@use_r3_smbody*/R3;
    state1 {
      implementsReq /*@use_r4_state*/R4;
      entry / { doSomething(); }
      do { keepDoing(); }
      e -> state2;
      substate1 { }
    }
    state2 { e -> state1; }
  }
}

// Completion probe — cursor inside implementsReq X; should see requirement scope.
implementsReq /*@complete_top*/R1;
