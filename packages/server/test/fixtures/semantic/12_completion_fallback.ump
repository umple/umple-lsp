// Each incomplete construct isolated in its own class to prevent cascading parse errors
interface I {}
enum Color { RED }

class IsATest {
  isA /*@isA_empty*/
}

class BeforeTest {
  void ping() {}
  void pong() {}
  before /*@before_empty*/
}

// Topic 052 item 2 — typed-prefix + `after` parity.
class BeforeTypedTest {
  void ping() {}
  void pong() {}
  before p/*@before_typed*/
}

class AfterTest {
  void ping() {}
  void pong() {}
  after /*@after_empty*/
}

class AfterTypedTest {
  void ping() {}
  void pong() {}
  after p/*@after_typed*/
}

class ArrowTest {
  status {
    Open {
      go -> /*@arrow_empty*/
    }
    Closed {}
  }
}

class RefSmTest {
  status { On {} Off {} }
  door as /*@refsm_empty*/
}
