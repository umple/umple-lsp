{
  "name": "umple-lsp-server",
  "version": "0.2.9",
  "description": "Language Server Protocol implementation for the Umple modeling language",
  "main": "out/server.js",
  "bin": {
    "umple-lsp-server": "bin/umple-lsp-server"
  },
  "files": [
    "out/",
    "bin/",
    "tree-sitter-umple.wasm",
    "references.scm",
    "definitions.scm",
    "completions.scm"
  ],
  "scripts": {
    "compile": "tsc -p .",
    "compile:test": "tsc -p tsconfig.test.json",
    "watch": "tsc -watch -p .",
    "test": "npm run compile:test && node .test-out/test/semantic.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/umple/umple-lsp.git",
    "directory": "packages/server"
  },
  "keywords": [
    "umple",
    "lsp",
    "language-server",
    "modeling"
  ],
  "license": "MIT",
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "web-tree-sitter": "0.26.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
